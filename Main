<script>
(function(){
  var SECS=['work','explore','about','contact'];
  var wipe=null;

  function show(id){
    var hw=document.getElementById('hw');
    var go=function(){
      if(id==='home'){
        hw.style.display='';
        SECS.forEach(function(s){var e=document.getElementById(s);if(e)e.classList.remove('active');});
      } else {
        hw.style.display='none';
        SECS.forEach(function(s){var e=document.getElementById(s);if(e)e.classList.toggle('active',s===id);});
        window.scrollTo({top:0,behavior:'instant'});
        setTimeout(function(){
          document.querySelectorAll('#'+id+' .rv').forEach(function(el,i){
            el.style.transitionDelay=(i*.05)+'s';
            var io=new IntersectionObserver(function(en){en.forEach(function(e){if(e.isIntersecting){e.target.classList.add('vis');io.unobserve(e.target);}});},{threshold:0.04});
            io.observe(el);
          });
        },80);
      }
    };
    if(!wipe){go();return;}
    wipe.className='in';
    setTimeout(function(){go();wipe.className='out';setTimeout(function(){wipe.className='';},450);},430);
  }

  function toast(m){var e=document.getElementById('toast');if(!e)return;e.textContent=m;e.classList.add('show');setTimeout(function(){e.classList.remove('show');},2800);}

  function send(){
    var n=(document.getElementById('fn')||{}).value||'';
    var em=(document.getElementById('fe')||{}).value||'';
    var msg=(document.getElementById('fm')||{}).value||'';
    n=n.trim();em=em.trim();msg=msg.trim();
    if(!n||!em||!msg){toast('Please fill all required fields');return;}
    window.open('https://mail.google.com/mail/?view=cm&to=miyajlowebdesign@gmail.com&su='+encodeURIComponent('Project Inquiry from '+n)+'&body='+encodeURIComponent('Hi Miyajlo,\n\n'+msg+'\n\nFrom: '+n+'\nReply to: '+em),'_blank');
  }

  document.addEventListener('DOMContentLoaded',function(){

    /* ── INTRO ── */
    var introEl=document.getElementById('intro');
    var wordEl=document.getElementById('intro-word');
    var countEl=document.getElementById('intro-count');
    var progEl=document.getElementById('intro-progress');
    var iCv=document.getElementById('intro-canvas');
    var ic=iCv.getContext('2d');
    iCv.width=window.innerWidth;iCv.height=window.innerHeight;
    var iL=[];
    for(var li=0;li<Math.ceil(window.innerHeight/18)+12;li++)
      iL.push({y:-200+li*18,spd:.06+Math.random()*.05,op:.18+Math.random()*.45});
    (function iDraw(){
      if(!introEl.parentNode)return;
      ic.clearRect(0,0,iCv.width,iCv.height);
      var a=-20*Math.PI/180,iw=iCv.width+400;
      iL.forEach(function(l){ic.save();ic.translate(0,l.y);ic.rotate(a);ic.beginPath();ic.moveTo(-200,0);ic.lineTo(iw,0);ic.strokeStyle='rgba(255,255,255,'+l.op+')';ic.lineWidth=.5;ic.stroke();ic.restore();l.y+=l.spd;if(l.y>iCv.height+200)l.y=-200;});
      requestAnimationFrame(iDraw);
    })();

    var FONTS=["Impact,'Arial Black',sans-serif","Georgia,'Times New Roman',serif","'Courier New',Courier,monospace","'Palatino Linotype',Palatino,serif","'Arial Narrow',Arial,sans-serif","Garamond,serif","'Trebuchet MS',Helvetica,sans-serif","'Comic Sans MS','Chalkboard SE',cursive","'Franklin Gothic Medium','Arial Narrow',Arial,sans-serif","'Gill Sans','Gill Sans MT',Calibri,sans-serif","'Rockwell','Courier Bold',serif","Verdana,Geneva,sans-serif","'Century Gothic',CenturyGothic,AppleGothic,sans-serif","'Brush Script MT','Segoe Script',cursive","'Copperplate Gothic Bold','Copperplate',fantasy","'Lucida Handwriting','Lucida Calligraphy',cursive","'Papyrus',fantasy","'Baskerville','Baskerville Old Face',serif","'Zapf Chancery','URW Chancery L',cursive","'Optima',Candara,Gill,sans-serif"];
    var STYLES=[{ls:'-4px',fw:'900'},{ls:'8px',fw:'400'},{ls:'-2px',fw:'800'},{ls:'12px',fw:'300'},{ls:'-6px',fw:'700'},{ls:'2px',fw:'600'},{ls:'0px',fw:'900'},{ls:'-3px',fw:'400'},{ls:'6px',fw:'700'}];
    var TOTAL=3200,INT=90,totalF=Math.floor(TOTAL/INT),frame=0,lastIdx=-1;
    var iTimer=setInterval(function(){
      frame++;
      var idx;do{idx=Math.floor(Math.random()*FONTS.length);}while(idx===lastIdx);lastIdx=idx;
      var st=STYLES[idx%STYLES.length];
      wordEl.style.fontFamily=FONTS[idx];wordEl.style.letterSpacing=st.ls;wordEl.style.fontWeight=st.fw;
      if(Math.random()<.18){wordEl.classList.add('flash');setTimeout(function(){wordEl.classList.remove('flash');},75);}
      var pct=(frame/totalF)*100;progEl.style.width=pct+'%';progEl.style.transition='width '+INT+'ms linear';
      countEl.textContent=(idx+1)+' / '+FONTS.length;
      if(frame>=totalF){
        clearInterval(iTimer);
        wordEl.style.fontFamily="'Syne',sans-serif";wordEl.style.letterSpacing='-4px';wordEl.style.fontWeight='900';
        wordEl.classList.remove('flash');progEl.style.width='100%';
        setTimeout(function(){introEl.classList.add('out');setTimeout(function(){introEl.style.display='none';},650);},300);
      }
    },INT);

    var PROJECTS=[
      {tag:'Web Design',name:'Red Futuristic',img:'Project1.png'},
      {tag:'Web Design',name:'Minimalistic Menu',img:'Project2.png'},
      {tag:'Web Design',name:'Resume Panel',img:'Project3.png'},
      {tag:'Web Design',name:'Perfect Panel',img:'Project4.png'},
      {tag:'Web Design',name:'Futuristic Hero',img:'Project5.png'},
      {tag:'Web Design',name:'Futuristic Hero',img:'Project6.png'}
    ];

    var grid=document.getElementById('work-grid');
    if(grid){
      PROJECTS.forEach(function(p,i){
        var card=document.createElement('div');
        card.className='wc rv';
        card.innerHTML=
          '<div class="wci">'
          +'<div class="wc-fallback bg'+(i%10)+'"></div>'
          +'<img class="wc-img" src="'+p.img+'" alt="'+p.name+'" loading="lazy">'
          +'<div class="wglow"></div>'
          +'<div class="w-num">'+String(i+1).padStart(2,'0')+'</div>'
          +'</div>'
          +'<div class="winfo">'
          +'<div class="w-tag">'+p.tag+'</div>'
          +'<div class="w-name">'+p.name+'</div>'
          +'</div>';
        grid.appendChild(card);
      });
    }

    /* ── NAV / MENU ── */
    function g(x){return document.getElementById(x);}
    wipe=g('page-wipe');
    var hbg=g('hbg'),menu=g('menu'),open=false;
    function toggleMenu(){open=!open;hbg.classList.toggle('open',open);menu.classList.toggle('open',open);}
    function closeMenu(){open=false;hbg.classList.remove('open');menu.classList.remove('open');}
    function navTo(s){closeMenu();setTimeout(function(){show(s);},280);}

    hbg.addEventListener('click',toggleMenu);
    g('n-logo').addEventListener('click',function(){closeMenu();show('home');});
    g('n-contact').addEventListener('click',function(){navTo('contact');});
    g('ml-work').addEventListener('click',function(){navTo('work');});
    g('ml-explore').addEventListener('click',function(){navTo('explore');});
    g('ml-about').addEventListener('click',function(){navTo('about');});
    g('ml-contact').addEventListener('click',function(){navTo('contact');});
    g('ml-home').addEventListener('click',function(){navTo('home');});
    g('cw').addEventListener('click',function(){show('work');});
    g('cc').addEventListener('click',function(){show('contact');});
    g('fsb').addEventListener('click',send);
    document.addEventListener('keydown',function(e){if(e.key==='Escape')closeMenu();});

    /* ── CURSOR ── */
    var cur=g('cursor'),ring=g('cursor-ring'),mx=0,my=0,rx=0,ry=0;
    document.addEventListener('mousemove',function(e){mx=e.clientX;my=e.clientY;cur.style.left=mx+'px';cur.style.top=my+'px';});
    (function ar(){rx+=(mx-rx)*.12;ry+=(my-ry)*.12;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(ar);})();
    document.querySelectorAll('button,a,.skill,.c-soc-link,.c-detail').forEach(function(el){el.addEventListener('mouseenter',function(){document.body.classList.add('hov');});el.addEventListener('mouseleave',function(){document.body.classList.remove('hov');});});
    document.addEventListener('mouseover',function(e){if(e.target.closest('.wc,.exp-item,.menu-link')){document.body.classList.add('hov');}});
    document.addEventListener('mouseout',function(e){if(e.target.closest('.wc,.exp-item,.menu-link')){document.body.classList.remove('hov');}});

    /* ── CANVAS LINES ── */
    var cv=g('lc'),ctx=cv.getContext('2d'),lines=[];
    function resize(){cv.width=window.innerWidth;cv.height=window.innerHeight;}resize();window.addEventListener('resize',resize);
    for(var i=0;i<Math.ceil(window.innerHeight/18)+12;i++)lines.push({y:-200+i*18,spd:.07+Math.random()*.06,op:.2+Math.random()*.45});
    (function draw(){ctx.clearRect(0,0,cv.width,cv.height);var a=-20*Math.PI/180,w=cv.width+400;lines.forEach(function(l){ctx.save();ctx.translate(0,l.y);ctx.rotate(a);ctx.beginPath();ctx.moveTo(-200,0);ctx.lineTo(w,0);ctx.strokeStyle='rgba(255,255,255,'+l.op+')';ctx.lineWidth=.5;ctx.stroke();ctx.restore();l.y+=l.spd;if(l.y>cv.height+200)l.y=-200;});requestAnimationFrame(draw);})();

    /* ── PARALLAX ── */
    document.addEventListener('mousemove',function(e){var xp=(e.clientX/window.innerWidth-.5)*10,yp=(e.clientY/window.innerHeight-.5)*10,img=g('hi');if(img)img.style.transform='translate('+(xp*.4)+'px,'+(yp*.4)+'px) scale(1.04)';});

    /* ── LIGHTBOX ── */
    var lb=g('lightbox');
    var lbImg=g('lightbox-img');
    var lbName=g('lightbox-name');
    var lbTag=g('lightbox-tag');
    var lbCounter=g('lightbox-counter');
    var lbClose=g('lightbox-close');
    var lbPrev=g('lightbox-prev');
    var lbNext=g('lightbox-next');
    var lbProjects=[];
    var lbIndex=0;

    function openLightbox(idx){
      lbIndex=idx;
      var p=lbProjects[idx];
      lbImg.src=p.img;
      lbImg.alt=p.name;
      lbName.textContent=p.name;
      lbTag.textContent=p.tag+' — ';
      lbCounter.textContent=(idx+1)+' / '+lbProjects.length;
      lb.classList.add('open');
      document.body.style.overflow='hidden';
    }
    function closeLightbox(){
      lb.classList.remove('open');
      document.body.style.overflow='';
    }
    function lbGo(dir){
      lbIndex=(lbIndex+dir+lbProjects.length)%lbProjects.length;
      lbImg.style.opacity='0';
      lbImg.style.transform='scale(.96)';
      setTimeout(function(){
        var p=lbProjects[lbIndex];
        lbImg.src=p.img;
        lbImg.alt=p.name;
        lbName.textContent=p.name;
        lbTag.textContent=p.tag+' — ';
        lbCounter.textContent=(lbIndex+1)+' / '+lbProjects.length;
        lbImg.style.opacity='1';
        lbImg.style.transform='scale(1)';
      },180);
    }
    lbImg.style.transition='opacity .18s ease, transform .18s ease';

    setTimeout(function(){
      var cards=document.querySelectorAll('.wc');
      cards.forEach(function(card,i){
        lbProjects.push({
          img:card.querySelector('.wc-img').src,
          name:card.querySelector('.w-name').textContent,
          tag:card.querySelector('.w-tag').textContent
        });
        card.querySelector('.wc-img').addEventListener('click',function(e){
          e.stopPropagation();
          openLightbox(i);
        });
      });
    },100);

    lbClose.addEventListener('click',closeLightbox);
    lbPrev.addEventListener('click',function(){lbGo(-1);});
    lbNext.addEventListener('click',function(){lbGo(1);});
    lb.addEventListener('click',function(e){if(e.target===lb)closeLightbox();});
    document.addEventListener('keydown',function(e){
      if(!lb.classList.contains('open'))return;
      if(e.key==='Escape')closeLightbox();
      if(e.key==='ArrowLeft')lbGo(-1);
      if(e.key==='ArrowRight')lbGo(1);
    });
  });
})();
</script>
</body>
